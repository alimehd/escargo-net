# Copy this file to .env.local for local development with `vercel dev`
# Set these same variables in your Vercel project's Environment Variables dashboard.

# Your Neon database connection string (found in the Neon dashboard under Connection Details)
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Comma-separated list of admin email addresses (no spaces around commas)
ADMIN_EMAILS=admin1@example.com,admin2@example.com,admin3@example.com
